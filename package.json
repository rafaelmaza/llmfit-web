{
  "name": "llmfit-web",
  "version": "0.1.0",
  "description": "Web interface for llmfit — find what LLM runs on your hardware",
  "type": "module",
  "main": "src/scoring.js",
  "scripts": {
    "test": "node --test test/**/*.test.js",
    "test:unit": "node --test test/scoring.test.js",
    "test:integration": "node test/integration.test.js",
    "dev": "python3 -m http.server 8000 --directory .",
    "server": "node server.js",
    "start": "node server.js",
    "record:demo": "node scripts/record-demo.mjs",
    "generate:gif": "node scripts/generate-demo-gif.mjs"
  },
  "keywords": [
    "llm",
    "hardware",
    "model-fit",
    "gpu",
    "inference"
  ],
  "author": "Contributor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafaelmaza/llmfit-web.git"
  },
  "homepage": "https://rafaelmaza.github.io/llmfit-web/",
  "bugs": {
    "url": "https://github.com/rafaelmaza/llmfit-web/issues"
  },
  "devDependencies": {
    "gifenc": "^1.0.3",
    "playwright": "^1.50.0",
    "pngjs": "^7.0.0"
  }
}
